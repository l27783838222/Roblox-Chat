local function CheckIfSenderIsBanned(senderName)
    local isBanned = false
    pcall(function()
        isBanned = ChatBanStore:GetAsync(senderName) == true
    end)
    return isBanned
end

local last_count = 0
task.spawn(function()
    while true do
        pcall(function()
            local res = request({
                Url = SERVER_URL .. "/get_chat",
                Method = "GET"
            })
            
            if res.StatusCode == 200 then
                local data = HttpService:JSONDecode(res.Body)
                
                if isFirstLoad then
                    last_count = #data.messages
                    isFirstLoad = false
                end
                
                if #data.messages > last_count then
                    for i = last_count + 1, #data.messages do
                        local fullMessage = data.messages[i]
                        local isPlayerMuted = false
                        local currentTime = os.time()
                        
                        local cleanName = string.match(fullMessage, "%[(.-)%]") or string.match(fullMessage, "Creator | (.-):") or ""
                        if cleanName and string.sub(cleanName, 1, 12) == "👑 Creator | " then
                            cleanName = string.sub(cleanName, 13)
                        end
                        
                        local isBanned = false
                        if cleanName ~= "" and cleanName ~= CREATOR_USERNAME then
                            isBanned = CheckIfSenderIsBanned(cleanName)
                        end
                        
                        if not isBanned then
                            for mutedName, expire in pairs(mutedPlayers) do
                                if (string.find(fullMessage, "%[" .. mutedName .. "%]") or string.find(fullMessage, "Creator | " .. mutedName)) 
                                   and not string.find(fullMessage, CREATOR_USERNAME) then
                                    if currentTime < expire then
                                        isPlayerMuted = true
                                    else
                                        mutedPlayers[mutedName] = nil
                                    end
                                    break
                                end
                            end
                            
                            if not isPlayerMuted then
                                local isCreatorMsg = string.find(fullMessage, "%[👑 Creator") ~= nil
                                AddOldSchoolMessage(fullMessage, false, isCreatorMsg)
                            end
                        end
                    end
                    last_count = #data.messages
                end
            end
        end)
        task.wait(0.5) 
    end
end)

