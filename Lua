-- ✨ وظيفة إدراج الرسالة داخل الصندوق المرئي على الشاشة
local function AddMessageToChatBox(text)
    local MessageLabel = Instance.new("TextLabel")
    MessageLabel.Parent = ChatBox
    MessageLabel.Size = UDim2.new(1, -10, 0, 22)
    MessageLabel.BackgroundTransparency = 1
    MessageLabel.TextColor3 = Color3.fromRGB(240, 240, 240)
    MessageLabel.TextXAlignment = Enum.TextXAlignment.Right 
    MessageLabel.TextSize = 14
    MessageLabel.Text = text
    
    -- النزول التلقائي لآخر رسالة وصلت
    ChatBox.CanvasPosition = Vector2.new(0, ChatBox.AbsoluteCanvasSize.Y)
end

-- 📡 وظيفة إرسال الرسالة إلى سيرفر بايثون في تيرمكس
local function SendMessageToServer(text)
    local payload = {
        username = LocalPlayer.Name,
        message = text
    }
    
    pcall(function()
        return request({
            Url = SERVER_URL .. "/send_message",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode(payload)
        })
    end)
end

-- متغيرات التحكم في ليمت منع السبام (1 ثانية)
local canSend = true
local cooldownTime = 1.0

-- تفعيل زر الإرسال عند الضغط مع العداد التنازلي المطور
SendButton.MouseButton1Click:Connect(function()
    if TextBox.Text ~= "" and canSend then
        canSend = false
        
        SendMessageToServer(TextBox.Text)
        TextBox.Text = "" 
        
        -- تحويل الزر للون الأحمر وبدء العد التنازلي بأجزاء الثانية
        SendButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        
        local timeLeft = cooldownTime
        while timeLeft > 0 do
            SendButton.Text = string.format("%.2f", timeLeft)
            task.wait(0.05)
            timeLeft = timeLeft - 0.05
        end
        
        -- إعادة الزر لطبيعته
        SendButton.Text = "إرسال"
        SendButton.BackgroundColor3 = Color3.fromRGB(0, 140, 255)
        canSend = true
    end
end)

-- 📥 وظيفة جلب شات السيرفر باستمرار وتحديث القائمة أمام اللاعبين
local last_count = 0
task.spawn(function()
    while true do
        pcall(function()
            local res = request({
                Url = SERVER_URL .. "/get_chat",
                Method = "GET"
            })
            
            if res.StatusCode == 200 then
                local data = game:GetService("HttpService"):JSONDecode(res.Body)
                if #data.messages > last_count then
                    for i = last_count + 1, #data.messages do
                        AddMessageToChatBox(data.messages[i])
                    end
                    last_count = #data.messages
                end
            end
        end)
        task.wait(2) -- سحب التحديثات كل ثانيتين
    end
end)

-- إرسال إشعار دخول اللاعب
