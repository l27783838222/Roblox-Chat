end

local function SendMessageToServer(text)
    local senderName = LocalPlayer.Name
    if senderName == CREATOR_USERNAME then
        senderName = "👑 Creator | " .. CREATOR_USERNAME
    end

    local payload = {
        username = senderName,
        message = text
    }
    
    pcall(function()
        return request({
            Url = SERVER_URL .. "/send_message",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

local canSend = true
local cooldownTime = 0.20

local function ProcessMessageSubmission()
    if TextBox.Text ~= "" and canSend then
        local msg = TextBox.Text
        TextBox.Text = ""
        
        if LocalPlayer.Name == CREATOR_USERNAME then
            if string.sub(msg, 1, 6) == "/mute " then
                local args = string.split(string.sub(msg, 7), " ")
                local targetName = args[1]
                local durationStr = args[2]
                
                if targetName and targetName ~= "" then
                    if targetName == CREATOR_USERNAME or string.find(targetName, CREATOR_USERNAME) then
                        AddOldSchoolMessage("[System]: You cannot mute yourself!", true, false)
                    else
                        local duration = ParseDuration(durationStr)
                        local expireTime = duration and (os.time() + duration) or tonumber(0x7FFFFFFF)
                        mutedPlayers[targetName] = expireTime
                        
                        local timeMsg = durationStr and (" for " .. durationStr) or " permanently"
                        AddOldSchoolMessage("[System]: Player '" .. targetName .. "' has been muted" .. timeMsg .. ".", true, false)
                    end
                end
                return
            elseif string.sub(msg, 1, 8) == "/unmute " then
                local targetName = string.sub(msg, 9)
                if targetName and targetName ~= "" then
                    if mutedPlayers[targetName] then
                        mutedPlayers[targetName] = nil
                        AddOldSchoolMessage("[System]: Player '" .. targetName .. "' has been unmuted.", true, false)
                    else
                        AddOldSchoolMessage("[System]: Player '" .. targetName .. "' is not muted.", true, false)
                    end
                end
                return
            elseif string.sub(msg, 1, 5) == "/ban " then
                local targetName = string.sub(msg, 6)
                if targetName and targetName ~= "" then
                    if targetName == CREATOR_USERNAME or string.find(targetName, CREATOR_USERNAME) then
                        AddOldSchoolMessage("[System]: You cannot ban yourself!", true, false)
                    else
                        pcall(function()
                            ChatBanStore:SetAsync(targetName, true)
                        end)
                        AddOldSchoolMessage("[System]: Player '" .. targetName .. "' has been PERMANENTLY banned from the system via DataStore.", true, false)
                    end
                end
                return
            elseif string.sub(msg, 1, 7) == "/unban " then
                local targetName = string.sub(msg, 8)
                if targetName and targetName ~= "" then
                    pcall(function()
                        ChatBanStore:SetAsync(targetName, false)
                    end)
                    AddOldSchoolMessage("[System]: Player '" .. targetName .. "' has been unbanned from DataStore.", true, false)
                end
                return
            end
        end
        
        canSend = false
        SendMessageToServer(msg)
        
        task.wait(cooldownTime)
        canSend = true
    end
end

