local function AddOldSchoolMessage(messageText, isSystemAlert, isCreatorMessage)
    local MessageFrame = Instance.new("Frame")
    MessageFrame.Size = UDim2.new(1, -10, 0, 0) 
    MessageFrame.AutomaticSize = Enum.AutomaticSize.Y 
    MessageFrame.BackgroundTransparency = 1
    MessageFrame.Parent = ChatBox

    local TextLabel = Instance.new("TextLabel")
    TextLabel.Size = UDim2.new(1, 0, 1, 0)
    TextLabel.AutomaticSize = Enum.AutomaticSize.Y
    TextLabel.BackgroundTransparency = 1
    TextLabel.Text = messageText
    
    if isSystemAlert then
        TextLabel.TextColor3 = Color3.fromRGB(255, 85, 85)
        TextLabel.Font = Enum.Font.SourceSansBold
    elseif isCreatorMessage then
        TextLabel.TextColor3 = Color3.fromRGB(255, 215, 0)
        TextLabel.Font = Enum.Font.SourceSansBold
    else
        TextLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        TextLabel.Font = Enum.Font.SourceSans
    end
    
    TextLabel.TextSize = 15
    TextLabel.TextXAlignment = Enum.TextXAlignment.Left
    TextLabel.TextYAlignment = Enum.TextYAlignment.Top
    TextLabel.TextStrokeTransparency = 0.6
    TextLabel.TextWrapped = true 
    TextLabel.Parent = MessageFrame

    task.spawn(function()
        task.wait(0.05)
        ChatBox.CanvasPosition = Vector2.new(0, ChatBox.AbsoluteCanvasSize.Y)
    end)

    if not ChatFrame.Visible and not isSystemAlert then
        unreadCount = unreadCount + 1
        BadgeLabel.Text = tostring(unreadCount)
        BadgeFrame.Visible = true
    end
end

local function SendMessageToServer(text)
    local senderName = LocalPlayer.Name
    if senderName == CREATOR_USERNAME then
        senderName = "👑 Creator | " .. CREATOR_USERNAME
    end

    local payload = {
        username = senderName,
        message = text
    }
    
    pcall(function()
        return request({
            Url = SERVER_URL .. "/send_message",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end)
end

local canSend = true
local cooldownTime = 0.50

local function ProcessMessageSubmission()
    if TextBox.Text ~= "" and canSend then
        local msg = TextBox.Text
        TextBox.Text = ""
        
        canSend = false
        task.spawn(function()
            SendMessageToServer(msg)
        end)
        
        task.wait(cooldownTime)
        canSend = true
    end
end

TextBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        ProcessMessageSubmission()
    end
end)

local function ToggleChatStyle(forceState)
    if forceState ~= nil then
        ChatFrame.Visible = forceState
    else
        ChatFrame.Visible = not ChatFrame.Visible
    end
    
    if ChatFrame.Visible then
        ClassicChatIcon.TextTransparency = 0 
        unreadCount = 0
        BadgeFrame.Visible = false
    else
        ClassicChatIcon.TextTransparency = 0.55 
    end
end

ClassicChatIcon.MouseButton1Click:Connect(function()
    ToggleChatStyle()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Slash and not gameProcessed then
        task.wait(0.05)
        ToggleChatStyle(true)
        TextBox:CaptureFocus()
    end
end)

task.spawn(function()
    while true do
        local success, err = pcall(function()
            local res = request({
                Url = SERVER_URL .. "/get_chat",
                Method = "GET"
            })
            
            if res and res.StatusCode == 200 then
                local data = HttpService:JSONDecode(res.Body)
                
                if isFirstLoad then
                    last_count = #data.messages
                    isFirstLoad = false
                end
                
                if #data.messages > last_count then
                    for i = last_count + 1, #data.messages do
                        local fullMessage = data.messages[i]
                        local isCreatorMsg = string.find(fullMessage, "%[👑 Creator") ~= nil
                        AddOldSchoolMessage(fullMessage, false, isCreatorMsg)
                    end
                    last_count = #data.messages
                end
            end
        end)
        task.wait(1.2) 
    end
end)

task.spawn(function()
    task.wait(1)
    SendMessageToServer("Connected to global chat!")
end)
